PORT=
API_BASE_URL=
INTERNAL_API_KEY=

# ── WhatsApp (Meta Cloud API) ──────────────────────────────────────────────────
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=

# URL pública da imagem de boas-vindas (deve ser acessível pela internet)
IMAGEM_URL=

# ── South ─────────────────────────────────────────────────────────────────────
SOUTH_BASE_URL=
SOUTH_TOKEN=

# ── I9 ────────────────────────────────────────────────────────────────────────
TOKEN_I9=
I9_BOLETO_URL=

# ── Chat AVSEG (substituto do Chatwoot) ────────────────────────────────────────
# Ativa o encaminhamento de mensagens do WhatsApp para o chat-avseg e a recepção
# das rotas /enviar-mensagem e /chat/finalizar chamadas pelo chat-avseg.
# INTERNAL_API_KEY (acima) precisa ser IDÊNTICA à do backend/.env do chat-avseg.
CHAT_AVSEG_ENABLED=
CHAT_AVSEG_URL=
# URL pública deste bot (usada para montar o link de anexos enviados ao chat-avseg,
# ex: https://botavseg.hvsn.com.br). Sem isso, anexos do cliente não são encaminhados.
BOT_PUBLIC_URL=
